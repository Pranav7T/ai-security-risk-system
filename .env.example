# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Model Configuration
MODEL_PATH=model/model.pkl

# API Configuration
API_VERSION=1.0.0
API_NAME=AI Security Risk Detection API

# Optional: Logging
LOG_LEVEL=INFO
LOG_FILE=api.log

# Database (optional; default: instance/app.db)
# DATABASE_PATH=instance/app.db

# MongoDB (for signup/login/dashboard and usage tracking)
# MONGODB_URI=mongodb://localhost:27017/
# MONGODB_DB=ai_security
